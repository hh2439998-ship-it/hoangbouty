local ESP_Objects = {}

local function CreateESP(player)
    local esp = {
        Box = Drawing.new("Square"),
        Name = Drawing.new("Text"),
        HealthBar = Drawing.new("Line"),
        HealthText = Drawing.new("Text"),
        Distance = Drawing.new("Text")
    }
    
    esp.Box.Color = Color3.fromRGB(255, 50, 50)
    esp.Box.Thickness = 1.5
    esp.Box.Filled = false
    
    esp.Name.Color = Color3.fromRGB(255, 255, 255)
    esp.Name.Size = 15
    esp.Name.Center = true
    esp.Name.Outline = true
    
    esp.HealthBar.Color = Color3.fromRGB(0, 255, 0)
    esp.HealthBar.Thickness = 2.5
    
    esp.HealthText.Color = Color3.fromRGB(0, 255, 100)
    esp.HealthText.Size = 13
    esp.HealthText.Center = true
    esp.HealthText.Outline = true

    esp.Distance.Color = Color3.fromRGB(255, 215, 0)
    esp.Distance.Size = 13
    esp.Distance.Center = true
    esp.Distance.Outline = true

    ESP_Objects[player] = esp
end

local function RemoveESP(player)
    if ESP_Objects[player] then
        for _, drawing in pairs(ESP_Objects[player]) do
            drawing:Remove()
        end
        ESP_Objects[player] = nil
    end
end

for _, player in pairs(Players:GetPlayers()) do
    if player ~= LocalPlayer then CreateESP(player) end
end
Players.PlayerAdded:Connect(function(player) CreateESP(player) end)
Players.PlayerRemoving:Connect(RemoveESP)

local function EquipWeapon(weaponType)
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local char = LocalPlayer.Character
    if not char or not backpack or not char:FindFirstChild("Humanoid") then return end
    
    local targetTool = nil
    for _, tool in pairs(backpack:GetChildren()) do
        if tool:IsA("Tool") then
            local name = tool.Name:lower()
            if weaponType == "Melee" and (name:find("style") or name:find("combat") or name:find("claw") or name:find("god") or name:find("karate") or name:find("step") or name:find("fist") or name:find("sanguine")) then
                targetTool = tool; break
            elseif weaponType == "Sword" and (name:find("sword") or name:find("blade") or name:find("katana") or name:find("scythe") or name:find("dagger") or name:find("saber") or name:find("ttf") or name:find("pole") or name:find("hallow")) then
                targetTool = tool; break
            elseif weaponType == "Fruit" and (name:find("fruit") or name:find("dough") or name:find("leopard") or name:find("kitsune") or name:find("dragon") or name:find("spirit") or name:find("venom") or name:find("t-rex")) then
                targetTool = tool; break
            elseif weaponType == "Gun" and (name:find("gun") or name:find("rifle") or name:find("flintlock") or name:find("cannon") or name:find("musket") or name:find("kabucha")) then
                targetTool = tool; break
            elseif tool.Name:lower() == weaponType:lower() then
                targetTool = tool; break
            end
        end
    end
    
    if targetTool then
        char.Humanoid:EquipTool(targetTool)
    end
end

local function ActivateSkill(key)
    pcall(function()
        local keyCode = Enum.KeyCode[key]
        if keypress then
            keypress(keyCode.Value)
            task.wait(0.05)
            keyrelease(keyCode.Value)
        else
            VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
            task.wait(0.05)
            VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
        end
    end)
end

