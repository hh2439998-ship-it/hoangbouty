-- MUTLAK SESSİZ NİŞAN (GÖVDEYE YÜZDE 100 İSABET)
-- ==========================================
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    if Config.SilentAim and not checkcaller() then
        if method == "FireServer" or method == "InvokeServer" then
            local target = GetClosestPlayer()
            if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                -- Hedefin gövde verisi (Hitbox yönlendirmesi için)
                local targetBodyCF = target.Character.HumanoidRootPart.CFrame
                local targetBodyPos = target.Character.HumanoidRootPart.Position
                local modified = false
                
                -- Yetenek ve mermi verilerini doğrudan gövde koordinatlarına dönüştür
                for i, arg in pairs(args) do
                    if typeof(arg) == "CFrame" then
                        args[i] = targetBodyCF
                        modified = true
                    elseif typeof(arg) == "Vector3" then
                        args[i] = targetBodyPos
                        modified = true
                    elseif typeof(arg) == "table" then
                        for k, v in pairs(arg) do
                            if typeof(v) == "Vector3" then
                                arg[k] = targetBodyPos
                                modified = true
                            elseif typeof(v) == "CFrame" then
                                arg[k] = targetBodyCF
                                modified = true
                            end
                        end
                    end
                end
                
                if modified then
                    return oldNamecall(self, unpack(args))
                end
            end
        end
    end
    return oldNamecall(self, ...)
end)

