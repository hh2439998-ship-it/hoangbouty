-- TRUE SILENT AIM (Hook Mouse Hit)
-- ==========================================
local PlayerMouse = LocalPlayer:GetMouse()
local oldIndex
oldIndex = hookmetamethod(game, "__index", function(self, key)
    if Config.SilentAim and self == PlayerMouse and (key == "Hit" or key == "Target") then
        local target = GetClosestPlayer()
        if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
            if key == "Hit" then
                return target.Character.HumanoidRootPart.CFrame
            elseif key == "Target" then
                return target.Character.HumanoidRootPart
            end
        end
    end
    return oldIndex(self, key)
end)

-- Vòng lặp chính Aimbot & ESP
RunService.RenderStepped:Connect(function()
    local centerScreen = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    if Config.FovVisible then
        FOVCircle.Position = centerScreen
        FOVCircle.Radius = Config.FovRadius
        FOVCircle.Visible = true
    else
        FOVCircle.Visible = false
    end
    
    local target = GetClosestPlayer()
    
    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        local targetHRP = target.Character.HumanoidRootPart
        
        -- CAMERA AIMBOT CHUẨN LOCK: Không bị rung lắc
        if Config.AimbotEnabled then
            Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, targetHRP.Position)
        end
        
        -- Áp sát mục tiêu khi giữ chiêu
        if Config.TrackTarget and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local isHoldingSkill = UserInputService:IsKeyDown(Enum.KeyCode.Z) or UserInputService:IsKeyDown(Enum.KeyCode.X) or UserInputService:IsKeyDown(Enum.KeyCode.C) or UserInputService:IsKeyDown(Enum.KeyCode.V) or UserInputService:IsKeyDown(Enum.KeyCode.F)
            if isHoldingSkill then
                LocalPlayer.Character.HumanoidRootPart.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 3)
            end
        end
    end

    -- Cập nhật ESP
    for player, esp in pairs(ESP_Objects) do
        if Config.ESPEnabled and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
            local hrp = player.Character.HumanoidRootPart
            local hum = player.Character.Humanoid
            local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            
            if onScreen then
                local myPos = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character.HumanoidRootPart.Position or Vector3.new(0,0,0)
                local dist = math.floor((hrp.Position - myPos).Magnitude)
                local head = player.Character:FindFirstChild("Head")
                
                local headPos = Camera:WorldToViewportPoint(head and head.Position + Vector3.new(0, 0.5, 0) or hrp.Position + Vector3.new(0, 2, 0))
                local legPos = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
                local boxHeight = math.abs(headPos.Y - legPos.Y)
                local boxWidth = boxHeight * 0.6

                esp.Box.Size = Vector2.new(boxWidth, boxHeight)
                esp.Box.Position = Vector2.new(pos.X - boxWidth / 2, headPos.Y)
                esp.Box.Visible = true

                esp.Name.Text = player.DisplayName
                esp.Name.Position = Vector2.new(pos.X, headPos.Y - 20)
                esp.Name.Visible = true

                esp.Distance.Text = dist .. "m"
                esp.Distance.Position = Vector2.new(pos.X, legPos.Y + 5)
                esp.Distance.Visible = true

                local healthPercent = hum.Health / hum.MaxHealth
                esp.HealthBar.From = Vector2.new(pos.X - boxWidth / 2 - 5, legPos.Y)
                esp.HealthBar.To = Vector2.new(pos.X - boxWidth / 2 - 5, legPos.Y - (boxHeight * healthPercent))
                esp.HealthBar.Color = Color3.fromRGB(255 - (255 * healthPercent), 255 * healthPercent, 0)
                esp.HealthBar.Visible = true

                esp.HealthText.Text = math.floor(hum.Health) .. " HP"
                esp.HealthText.Position = Vector2.new(pos.X - boxWidth / 2 - 25, legPos.Y - (boxHeight * healthPercent) - 10)
                esp.HealthText.Visible = true
            else
                for _, v in pairs(esp) do v.Visible = false end
            end
        else
            for _, v in pairs(esp) do v.Visible = false end
        end
    end
end)

-- Biến chống spam macro
local IsMacroRunning = false
local function RunMacroCombo()
    if IsMacroRunning then return end
    IsMacroRunning = true
    for i = 1, #Config.MacroSequence do
        local step = Config.MacroSequence[i]
        EquipWeapon(step.Weapon)
        task.wait(0.1)
        ActivateSkill(step.Key)
        task.wait(step.Delay)
    end
    IsMacroRunning = false
end

