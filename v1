-- Lấy người chơi gần nhất trong vòng FOV
local function GetClosestPlayer()
    local closestPlayer = nil
    local shortestDistance = math.huge
    local mousePos = UserInputService:GetMouseLocation()

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
            local hrp = player.Character.HumanoidRootPart
            local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            
            if onScreen then
                local distance = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                if distance <= Config.FovRadius and distance < shortestDistance then
                    closestPlayer = player
                    shortestDistance = distance
                end
            end
        end
    end
    return closestPlayer
end

-- Tự động trang bị vũ khí dựa trên phân loại
local function EquipWeapon(weaponType)
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local character = LocalPlayer.Character
    if not character or not backpack then return end
    
    -- Hủy trang bị công cụ hiện tại trước
    for _, item in pairs(character:GetChildren()) do
        if item:IsA("Tool") then
            item.Parent = backpack
        end
    end
    
    -- Tìm vũ khí phù hợp trong balo
    for _, tool in pairs(backpack:GetChildren()) do
        if tool:IsA("Tool") then
            -- Kiểm tra thuộc tính hoặc tên của vũ khí (Ví dụ cơ bản)
            local match = false
            if weaponType == "Melee" and (tool:FindFirstChild("Combat") or tool:FindFirstChild("Melee") or string.find(tool.Name, "Style")) then match = true
            elseif weaponType == "Sword" and tool:FindFirstChild("Sword") then match = true
            elseif weaponType == "Fruit" and (string.find(tool.Name, "Fruit") or tool:FindFirstChild("Eat")) then match = true
            elseif weaponType == "Gun" and tool:FindFirstChild("Gun") then match = true
            end
            
            if match or tool.Name == weaponType then -- Dự phòng nếu đặt tên trùng trực tiếp
                tool.Parent = character
                break
            end
        end
    end
end

-- Kích hoạt phím kỹ năng ảo
local function ActivateSkill(key)
    -- Giả lập nhấn phím (Chỉ hoạt động trên các Executor hỗ trợ các hàm ảo)
    if keypress then
        local keyCode = Enum.KeyCode[key].Value
        keypress(keyCode)
        task.wait(0.05)
        keyrelease(keyCode)
    end
end

-- Vòng lặp duy trì Tốc độ chạy và Nhảy
task.spawn(function()
    while task.wait(0.1) do
        pcall(function()
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
                LocalPlayer.Character.Humanoid.WalkSpeed = Config.WalkSpeed
                LocalPlayer.Character.Humanoid.JumpPower = Config.JumpPower
                LocalPlayer.Character.Humanoid.UseJumpPower = true
            end
        end)
    end
end)

-- Vòng lặp Camera Aimbot và di chuyển theo địch khi giữ chiêu
RunService.RenderStepped:Connect(function()
    -- Cập nhật vòng tròn FOV
    if Config.FovVisible then
        FOVCircle.Position = UserInputService:GetMouseLocation()
        FOVCircle.Radius = Config.FovRadius
        FOVCircle.Visible = true
    else
        FOVCircle.Visible = false
    end
    
    -- Xử lý Aimbot Camera
    if Config.AimbotEnabled then
        local target = GetClosestPlayer()
        if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
            local targetHRP = target.Character.HumanoidRootPart
            -- Di chuyển Camera mượt mà về hướng mục tiêu
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetHRP.Position)
            
            -- Nếu bật tính năng tự bám đuôi khi giữ nút kỹ năng
            if Config.TrackTarget and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local isHoldingSkill = UserInputService:IsKeyDown(Enum.KeyCode.Z) or UserInputService:IsKeyDown(Enum.KeyCode.X) or UserInputService:IsKeyDown(Enum.KeyCode.C) or UserInputService:IsKeyDown(Enum.KeyCode.V) or UserInputService:IsKeyDown(Enum.KeyCode.F)
                if isHoldingSkill then
                    -- Di chuyển nhân vật của bạn áp sát mục tiêu
                    LocalPlayer.Character.HumanoidRootPart.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 3)
                end
            end
        end
    end
end)

-- Thực thi Macro Combo tuần tự
local function RunMacroCombo()
    if not Config.MacroEnabled then return end
    for i = 1, #Config.MacroSequence do
        if not Config.MacroEnabled then break end -- Dừng khẩn cấp nếu tắt nút
        local step = Config.MacroSequence[i]
        
        -- Bước 1: Đổi vũ khí
        EquipWeapon(step.Weapon)
        task.wait(0.1)
        
        -- Bước 2: Tung chiêu
        ActivateSkill(step.Key)
        
        -- Bước 3: Chờ thời gian giãn cách đã cài đặt
        task.wait(step.Delay)
    end
end

