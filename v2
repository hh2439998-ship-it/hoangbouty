local function CreateSlider(parent, name, min, max, default, yPos, callback)
    local Container = Instance.new("Frame")
    Container.Size = UDim2.new(0.9, 0, 0, 50)
    Container.Position = UDim2.new(0.05, 0, 0, yPos)
    Container.BackgroundTransparency = 1
    Container.Parent = parent

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(1, 0, 0, 20)
    Label.Text = name
    Label.TextColor3 = Color3.fromRGB(200, 200, 200)
    Label.TextSize = 14
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.BackgroundTransparency = 1
    Label.Parent = Container

    local SliderLine = Instance.new("Frame")
    SliderLine.Size = UDim2.new(0.8, 0, 0, 6)
    SliderLine.Position = UDim2.new(0, 0, 0, 30)
    SliderLine.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    SliderLine.BorderSizePixel = 0
    SliderLine.Parent = Container

    local FillLine = Instance.new("Frame")
    FillLine.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    FillLine.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
    FillLine.BorderSizePixel = 0
    FillLine.Parent = SliderLine

    local SliderBtn = Instance.new("TextButton")
    SliderBtn.Size = UDim2.new(0, 10, 0, 20)
    SliderBtn.Position = UDim2.new((default - min) / (max - min), -5, 0.5, -10)
    SliderBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    SliderBtn.Text = "|"
    SliderBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
    SliderBtn.TextSize = 12
    SliderBtn.Parent = SliderLine

    local ValueBox = Instance.new("TextLabel")
    ValueBox.Size = UDim2.new(0, 50, 0, 20)
    ValueBox.Position = UDim2.new(0.85, 0, 0, 23)
    ValueBox.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
    ValueBox.Text = tostring(default)
    ValueBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    ValueBox.TextSize = 14
    ValueBox.Parent = Container

    local dragging = false
    SliderBtn.MouseButton1Down:Connect(function() dragging = true end)
    
    UserInputService.InputEnded:Connect(function(input) 
        if input.UserInputType == Enum.UserInputType.MouseButton1 then 
            dragging = false 
        end 
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local mouseX = input.Position.X
            local lineLeft = SliderLine.AbsolutePosition.X
            local lineWidth = SliderLine.AbsoluteSize.X
            local percentage = math.clamp((mouseX - lineLeft) / lineWidth, 0, 1)
            
            SliderBtn.Position = UDim2.new(percentage, -5, 0.5, -10)
            FillLine.Size = UDim2.new(percentage, 0, 1, 0)
            
            local val = math.floor(min + (max - min) * percentage)
            ValueBox.Text = tostring(val)
            callback(val)
        end
    end)
end

