local function GetClosestPlayer()
    local closestPlayer = nil
    local shortestDistance = math.huge
    local centerScreen = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
            local hrp = player.Character.HumanoidRootPart
            local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            
            if onScreen then
                local distance = (Vector2.new(screenPos.X, screenPos.Y) - centerScreen).Magnitude
                if distance <= Config.FovRadius and distance < shortestDistance then
                    closestPlayer = player
                    shortestDistance = distance
                end
            end
        end
    end
    return closestPlayer
end

local function EquipWeapon(weaponType)
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local character = LocalPlayer.Character
    if not character or not backpack then return end
    
    for _, item in pairs(character:GetChildren()) do
        if item:IsA("Tool") then item.Parent = backpack end
    end
    
    for _, tool in pairs(backpack:GetChildren()) do
        if tool:IsA("Tool") then
            local match = false
            local toolName = tool.Name:lower()
            if weaponType == "Melee" and (tool:FindFirstChild("Combat") or tool:FindFirstChild("Melee") or toolName:find("style") or toolName:find("claw") or toolName:find("god")) then match = true
            elseif weaponType == "Sword" and (tool:FindFirstChild("Sword") or toolName:find("sword") or toolName:find("blade")) then match = true
            elseif weaponType == "Fruit" and (toolName:find("fruit") or tool:FindFirstChild("Eat") or toolName:find("dough") or toolName:find("leopard")) then match = true
            elseif weaponType == "Gun" and (tool:FindFirstChild("Gun") or toolName:find("gun") or toolName:find("rifle")) then match = true
            end
            
            if match or tool.Name == weaponType then
                tool.Parent = character
                break
            end
        end
    end
end

local function ActivateSkill(key)
    if keypress then
        local keyCode = Enum.KeyCode[key].Value
        keypress(keyCode)
        task.wait(0.05)
        keyrelease(keyCode)
    end
end

-- Vòng lặp chính Aimbot, Silent Aim, ESP
RunService.RenderStepped:Connect(function()
    local centerScreen = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    if Config.FovVisible then
        FOVCircle.Position = centerScreen
        FOVCircle.Radius = Config.FovRadius
        FOVCircle.Visible = true
    else
        FOVCircle.Visible = false
    end
    
    local target = GetClosestPlayer()
    
    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        local targetHRP = target.Character.HumanoidRootPart
        
        -- CAMERA AIMBOT: Nhích cam xuống một chút để khớp vạch lock xanh của game
        if Config.AimbotEnabled then
            local aimPos = targetHRP.Position - Vector3.new(0, 1.2, 0)
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, aimPos), 0.5)
        end
        
        -- SILENT AIM & TRACK: Quay mặt trực tiếp vào kẻ địch khi dùng chiêu
        if Config.SilentAim and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local isHoldingSkill = UserInputService:IsKeyDown(Enum.KeyCode.Z) or UserInputService:IsKeyDown(Enum.KeyCode.X) or UserInputService:IsKeyDown(Enum.KeyCode.C) or UserInputService:IsKeyDown(Enum.KeyCode.V) or UserInputService:IsKeyDown(Enum.KeyCode.F)
            if isHoldingSkill then
                -- Silent Aim: Xoay nhân vật hướng thẳng về địch
                LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.lookAt(LocalPlayer.Character.HumanoidRootPart.Position, Vector3.new(targetHRP.Position.X, LocalPlayer.Character.HumanoidRootPart.Position.Y, targetHRP.Position.Z))
                -- Track (Áp sát)
                if Config.TrackTarget then
                    LocalPlayer.Character.HumanoidRootPart.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 3)
                end
            end
        end
    end

    -- Cập nhật ESP
    for player, esp in pairs(ESP_Objects) do
        if Config.ESPEnabled and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
            local hrp = player.Character.HumanoidRootPart
            local hum = player.Character.Humanoid
            local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            
            if onScreen then
                local myPos = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character.HumanoidRootPart.Position or Vector3.new(0,0,0)
                local dist = math.floor((hrp.Position - myPos).Magnitude)
                local head = player.Character:FindFirstChild("Head")
                
                local headPos = Camera:WorldToViewportPoint(head and head.Position + Vector3.new(0, 0.5, 0) or hrp.Position + Vector3.new(0, 2, 0))
                local legPos = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
                local boxHeight = math.abs(headPos.Y - legPos.Y)
                local boxWidth = boxHeight * 0.6

                esp.Box.Size = Vector2.new(boxWidth, boxHeight)
                esp.Box.Position = Vector2.new(pos.X - boxWidth / 2, headPos.Y)
                esp.Box.Visible = true

                esp.Name.Text = player.DisplayName
                esp.Name.Position = Vector2.new(pos.X, headPos.Y - 20)
                esp.Name.Visible = true

                esp.Distance.Text = dist .. "m"
                esp.Distance.Position = Vector2.new(pos.X, legPos.Y + 5)
                esp.Distance.Visible = true

                -- Đọc Ken Haki (Dodge)
                local dodges = player.Character:FindFirstChild("Dodge") or player.Character:FindFirstChild("Dodges") or player.Character:FindFirstChild("Instinct")
                local kenCount = dodges and dodges.Value or "?"
                esp.Ken.Text = "Ken: " .. tostring(kenCount)
                esp.Ken.Position = Vector2.new(pos.X + boxWidth / 2 + 5, headPos.Y)
                esp.Ken.Visible = true

                local healthPercent = hum.Health / hum.MaxHealth
                esp.HealthBar.From = Vector2.new(pos.X - boxWidth / 2 - 5, legPos.Y)
                esp.HealthBar.To = Vector2.new(pos.X - boxWidth / 2 - 5, legPos.Y - (boxHeight * healthPercent))
                esp.HealthBar.Color = Color3.fromRGB(255 - (255 * healthPercent), 255 * healthPercent, 0)
                esp.HealthBar.Visible = true

                esp.HealthText.Text = math.floor(hum.Health) .. " HP"
                esp.HealthText.Position = Vector2.new(pos.X - boxWidth / 2 - 25, legPos.Y - (boxHeight * healthPercent) - 10)
                esp.HealthText.Visible = true
            else
                for _, v in pairs(esp) do v.Visible = false end
            end
        else
            for _, v in pairs(esp) do v.Visible = false end
        end
    end
end)

local function RunMacroCombo()
    if not Config.MacroEnabled then return end
    for i = 1, #Config.MacroSequence do
        if not Config.MacroEnabled then break end
        local step = Config.MacroSequence[i]
        
        EquipWeapon(step.Weapon)
        task.wait(0.1)
        ActivateSkill(step.Key)
        task.wait(step.Delay)
    end
end

