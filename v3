    local delays = {0.1, 0.3, 0.5, 0.8, 1.0, 1.5, 2.0}
    DelayBtn.MouseButton1Click:Connect(function()
        local idx = table.find(delays, Config.MacroSequence[i].Delay) or 1
        Config.MacroSequence[i].Delay = delays[(idx % #delays) + 1]
        DelayBtn.Text = Config.MacroSequence[i].Delay .. "s"
    end)
          end
