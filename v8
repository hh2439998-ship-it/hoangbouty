local VirtualInputManager = game:GetService("VirtualInputManager")

local function EquipWeaponFast(weaponType)
    local char = LocalPlayer.Character; local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not char or not backpack then return end

    local currentTool = char:FindFirstChildOfClass("Tool")
    if currentTool then
        local cName = currentTool.Name:lower()
        if (weaponType == "Melee" and cName:find("combat") or cName:find("style") or cName:find("claw") or cName:find("god") or cName:find("sanguine")) or
           (weaponType == "Sword" and cName:find("sword") or cName:find("blade") or cName:find("katana") or cName:find("spikey") or cName:find("cursed")) or
           (weaponType == "Fruit" and cName:find("fruit") or cName:find("dough") or cName:find("portal") or cName:find("rumble")) or
           (weaponType == "Gun" and cName:find("gun") or cName:find("soul") or cName:find("guitar") or cName:find("kabucha")) then
            return -- Đang cầm đúng hệ, không bị khựng (Hit-stun logic)
        end
    end

    for _, tool in pairs(backpack:GetChildren()) do
        if tool:IsA("Tool") then
            local name = tool.Name:lower()
            if (weaponType == "Melee" and (name:find("combat") or name:find("style") or name:find("god"))) or
               (weaponType == "Sword" and (name:find("sword") or name:find("katana") or name:find("blade"))) or
               (weaponType == "Fruit" and (name:find("fruit") or name:find("dough") or name:find("portal"))) or
               (weaponType == "Gun" and (name:find("gun") or name:find("guitar"))) then
                for _, item in pairs(char:GetChildren()) do if item:IsA("Tool") then item.Parent = backpack end end
                tool.Parent = char; break
            end
        end
    end
end

local function FireSkill(key)
    local keyCode = Enum.KeyCode[key]
    VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
    task.wait(0.02)
    VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
end

local IsMacroRunning = false
local function RunMacroCombo()
    if IsMacroRunning then return end
    IsMacroRunning = true
    for i = 1, #Config.MacroSequence do
        if not IsMacroRunning then break end
        local step = Config.MacroSequence[i]
        EquipWeaponFast(step.Weapon)
        task.wait(0.01) -- Swap delay triệt tiêu
        FireSkill(step.Key)
        task.wait(step.DelayMs / 1000) -- Độ trễ Mili-giây (Chống đối thủ bật Ken Haki)
    end
    IsMacroRunning = false
end

